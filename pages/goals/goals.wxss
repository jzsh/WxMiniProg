/* pages/goals/goals.wxss */
page { background: #f5f5f5; }
.container { padding: 20rpx 24rpx; padding-bottom: 140rpx; }
.progress-section { background: linear-gradient(135deg, #00b26a, #00d48a); border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; color: #fff; }
.progress-info { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.progress-text { font-size: 28rpx; opacity: 0.9; }
.progress-num { font-size: 32rpx; font-weight: bold; }
.progress-bar { height: 16rpx; background: rgba(255,255,255,0.3); border-radius: 8rpx; overflow: hidden; }
.progress-fill { height: 100%; background: #fff; border-radius: 8rpx; transition: width 0.3s; }
.goal-list { background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.goal-item { display: flex; align-items: center; padding: 24rpx 28rpx; border-bottom: 1rpx solid #f5f5f5; }
.goal-item:last-child { border-bottom: none; }
.goal-item.completed .goal-title { color: #ccc; text-decoration: line-through; }
.goal-content { flex: 1; display: flex; align-items: flex-start; }
.checkbox { width: 44rpx; height: 44rpx; border-radius: 50%; border: 3rpx solid #ddd; display: flex; align-items: center; justify-content: center; margin-right: 20rpx; font-size: 24rpx; color: transparent; flex-shrink: 0; }
.checkbox.checked { background: #00b26a; border-color: #00b26a; color: #fff; }
.goal-info { flex: 1; }
.goal-title { font-size: 28rpx; color: #333; font-weight: bold; }
.goal-desc { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.goal-deadline { font-size: 22rpx; color: #bbb; margin-top: 4rpx; }
.deadline-label { color: #ff6b6b; }
.goal-delete { font-size: 32rpx; color: #ccc; padding: 0 12rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.add-btn { position: fixed; bottom: 40rpx; right: 40rpx; width: 100rpx; height: 100rpx; border-radius: 50%; background: #00b26a; color: #fff; font-size: 48rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 24rpx rgba(0,178,106,0.4); }
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 200; display: flex; align-items: center; justify-content: center; }
.modal-content { background: #fff; border-radius: 20rpx; padding: 36rpx; width: 80%; max-height: 80vh; }
.modal-title { font-size: 34rpx; font-weight: bold; color: #333; margin-bottom: 28rpx; text-align: center; }
.form-item { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 8rpx; display: block; }
.form-input { background: #f7f7f7; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx; }
.form-textarea { background: #f7f7f7; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx; min-height: 120rpx; width: 100%; box-sizing: border-box; }
.form-picker { display: flex; justify-content: space-between; align-items: center; background: #f7f7f7; border-radius: 12rpx; padding: 16rpx 20rpx; }
.placeholder { color: #bbb; }
.picker-arrow { font-size: 40rpx; color: #ccc; }
.modal-actions { display: flex; gap: 20rpx; margin-top: 32rpx; }
.btn-cancel { flex: 1; text-align: center; padding: 20rpx; border-radius: 12rpx; font-size: 28rpx; color: #999; background: #f5f5f5; }
.btn-confirm { flex: 1; text-align: center; padding: 20rpx; border-radius: 12rpx; font-size: 28rpx; color: #fff; background: #00b26a; }
