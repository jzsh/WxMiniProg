/**index.wxss**/
.container {
  width: 100%;
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* ========== 轮播图 ========== */
.swiper {
  width: 100%;
  height: 360rpx;
}
.swiper image {
  width: 100%;
  height: 100%;
}

/* ========== 操作行 ========== */
.action-row {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 20rpx 24rpx;
  margin-top: 2rpx;
}
.marquee-box {
  flex: 1;
  overflow: hidden;
  height: 56rpx;
  line-height: 56rpx;
  margin-right: 24rpx;
}
.marquee-text {
  display: flex;
  white-space: nowrap;
  animation: marquee 12s linear infinite;
}
.marquee-content {
  font-size: 28rpx;
  color: #888;
}
@keyframes marquee {
  0%   { transform: translateX(0%); }
  100% { transform: translateX(-50%); }
}
.add-btn {
  display: flex;
  align-items: center;
  background-color: #00b26a;
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  flex-shrink: 0;
}
.add-btn:active {
  opacity: 0.8;
}
.add-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  margin-right: 8rpx;
}
.add-text {
  font-size: 24rpx;
  color: #fff;
}

/* ========== 日记列表 ========== */
.diary-section {
  padding: 20rpx 24rpx;
}
.diary-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

/* 卡片封面图 */
.diary-cover {
  position: relative;
  width: 100%;
  height: 300rpx;
}
.diary-cover image {
  width: 100%;
  height: 100%;
}
.diary-cover-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: rgba(0, 178, 106, 0.85);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 卡片信息区 */
.diary-info {
  padding: 24rpx 28rpx;
}
.diary-info-compact {
  padding: 20rpx 28rpx;
}
.diary-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.diary-date {
  font-size: 24rpx;
  color: #999;
}
.diary-mood {
  font-size: 22rpx;
  color: #888;
  background: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}
.diary-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}
.diary-summary {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.diary-footer {
  margin-top: 12rpx;
}
.diary-img-count {
  font-size: 22rpx;
  color: #bbb;
}

/* ========== 加载更多 ========== */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #999;
}
.load-more.nomore {
  padding: 40rpx 0;
}
.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #00b26a;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
