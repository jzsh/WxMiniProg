<!--pages/album/album.wxml-->
<view class="album-page">

  <!-- 顶部工具栏 -->
  <view class="toolbar">
    <text class="photo-count">{{photos.length}}张照片</text>
    <view class="mode-switch">
      <text class="mode-btn {{viewMode === 'grid' ? 'active' : ''}}" bindtap="switchMode" data-mode="grid">⊞</text>
      <text class="mode-btn {{viewMode === 'list' ? 'active' : ''}}" bindtap="switchMode" data-mode="list">☰</text>
    </view>
    <view class="upload-btn" bindtap="uploadPhotos">
      <text class="upload-icon">+</text>
      <text class="upload-text">上传</text>
    </view>
  </view>

  <!-- 轮播展示 -->
  <swiper class="album-swiper" wx:if="{{swiperImages.length > 0}}" indicator-dots autoplay interval="4000" duration="800" circular>
    <swiper-item wx:for="{{swiperImages}}" wx:key="*this">
      <image src="{{item}}" mode="aspectFill"></image>
    </swiper-item>
  </swiper>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{photos.length === 0}}">
    <text class="empty-icon">📷</text>
    <text class="empty-text">还没有照片</text>
    <text class="empty-hint">点击右上角上传按钮添加照片</text>
  </view>

  <!-- 网格模式 -->
  <view class="grid-view" wx:if="{{viewMode === 'grid' && photos.length > 0}}">
    <view class="grid-item" wx:for="{{photos}}" wx:key="index"
      bindtap="previewImage" data-src="{{item.src}}"
      bindlongpress="onLongPress" data-index="{{index}}">
      <image src="{{item.src}}" mode="aspectFill"></image>
    </view>
  </view>

  <!-- 列表模式 -->
  <view class="list-view" wx:if="{{viewMode === 'list' && photos.length > 0}}">
    <view class="list-item" wx:for="{{photos}}" wx:key="index"
      bindtap="previewImage" data-src="{{item.src}}"
      bindlongpress="onLongPress" data-index="{{index}}">
      <image src="{{item.src}}" mode="aspectFill"></image>
      <view class="list-info">
        <text class="list-date">{{item.date}}</text>
        <text class="list-label">点击查看大图</text>
      </view>
    </view>
  </view>

</view>
