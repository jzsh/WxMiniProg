/* pages/album/album.wxss */

page {
  background-color: #f5f5f5;
}

.album-page {
  min-height: 100vh;
  padding-bottom: 20rpx;
}

/* ========== 顶部工具栏 ========== */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.photo-count {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}
.mode-switch {
  display: flex;
  gap: 16rpx;
}
.mode-btn {
  font-size: 36rpx;
  color: #ccc;
  padding: 8rpx 12rpx;
}
.mode-btn.active {
  color: #00b26a;
}
.upload-btn {
  display: flex;
  align-items: center;
  background: #00b26a;
  border-radius: 32rpx;
  padding: 8rpx 24rpx;
}
.upload-btn:active {
  opacity: 0.8;
}
.upload-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  margin-right: 6rpx;
}
.upload-text {
  font-size: 24rpx;
  color: #fff;
}

/* ========== 轮播图 ========== */
.album-swiper {
  width: 100%;
  height: 360rpx;
}
.album-swiper image {
  width: 100%;
  height: 100%;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}
.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

/* ========== 网格模式 ========== */
.grid-view {
  display: flex;
  flex-wrap: wrap;
  padding: 4rpx;
}
.grid-item {
  width: 33.33%;
  padding: 4rpx;
  box-sizing: border-box;
}
.grid-item image {
  width: 100%;
  height: 240rpx;
  border-radius: 4rpx;
}

/* ========== 列表模式 ========== */
.list-view {
  padding: 20rpx 24rpx;
}
.list-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.list-item image {
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
}
.list-info {
  flex: 1;
  padding: 20rpx 28rpx;
  display: flex;
  flex-direction: column;
}
.list-date {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.list-label {
  font-size: 28rpx;
  color: #333;
}
