<!--pages/add_anniversary/add_anniversary.wxml-->
<view class="page">

  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">添加纪念日</text>
    <text class="page-subtitle">记录下这个特别的日子</text>
  </view>

  <!-- 表单内容 -->
  <view class="form-section">

    <!-- 标题 -->
    <view class="form-item">
      <view class="form-label">标题</view>
      <input
        class="form-input"
        placeholder="请输入标题"
        placeholder-class="placeholder"
        value="{{title}}"
        bindinput="onTitleInput"
        maxlength="30"
      />
    </view>

    <!-- 详情 -->
    <view class="form-item">
      <view class="form-label">纪念日详情</view>
      <textarea
        class="form-textarea"
        placeholder="今天发生了什么？把纪念日的详情在这里填写~"
        placeholder-class="placeholder"
        value="{{detail}}"
        bindinput="onDetailInput"
        maxlength="2000"
        auto-height
      />
    </view>

    <!-- 插入图片 -->
    <view class="form-item">
      <view class="form-label">图片 <text class="label-hint">(选填，最多{{maxImageCount}}张)</text></view>
      <view class="image-grid">
        <!-- 已选图片 -->
        <view class="image-item" wx:for="{{imageList}}" wx:key="*this">
          <image src="{{item}}" mode="aspectFill" bindtap="previewImage" data-src="{{item}}"></image>
          <view class="image-delete" catchtap="deleteImage" data-index="{{index}}">
            <text>×</text>
          </view>
        </view>
        <!-- 添加图片按钮 -->
        <view class="image-add" bindtap="chooseImage" wx:if="{{imageList.length < maxImageCount}}">
          <view class="add-icon-wrapper">
            <text class="camera-icon">📷</text>
            <text class="add-text">添加图片</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 日期选择 -->
    <view class="form-item">
      <view class="form-label">纪念日期</view>
      <picker mode="date" value="{{date}}" start="1950-01-01" end="2099-12-31" bindchange="onDateChange">
        <view class="date-picker-row">
          <text class="date-value" wx:if="{{date}}">{{date}}</text>
          <text class="date-value empty" wx:else>请选择日期</text>
          <text class="date-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 心情选择 -->
    <view class="form-item">
      <view class="form-label">心情</view>
      <view class="tag-picker-row" bindtap="selectMood">
        <text class="tag-value {{mood ? '' : 'empty'}}">{{mood || '选择心情'}}</text>
        <text class="date-arrow">›</text>
      </view>
      <view class="tag-options" wx:if="{{showMoodPicker}}">
        <view class="tag-option {{mood === item ? 'active' : ''}}" wx:for="{{moodOptions}}" wx:key="*this" bindtap="chooseMood" data-mood="{{item}}">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 天气选择 -->
    <view class="form-item">
      <view class="form-label">天气</view>
      <view class="tag-picker-row" bindtap="selectWeather">
        <text class="tag-value {{weather ? '' : 'empty'}}">{{weather || '选择天气'}}</text>
        <text class="date-arrow">›</text>
      </view>
      <view class="tag-options" wx:if="{{showWeatherPicker}}">
        <view class="tag-option {{weather === item ? 'active' : ''}}" wx:for="{{weatherOptions}}" wx:key="*this" bindtap="chooseWeather" data-weather="{{item}}">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 位置选择 -->
    <view class="form-item">
      <view class="form-label">位置</view>
      <view class="tag-picker-row" bindtap="chooseLocation">
        <text class="tag-value {{location ? '' : 'empty'}}">{{location || '选择位置'}}</text>
        <text class="date-arrow">›</text>
      </view>
    </view>

  </view>

  <!-- 发布按钮 -->
  <view class="publish-section">
    <view class="publish-btn" bindtap="onPublish">
      <text class="publish-text">发布</text>
    </view>
  </view>

</view>
