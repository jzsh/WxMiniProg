/* pages/add_anniversary/add_anniversary.wxss */

page {
  background-color: #f5f5f5;
}

.page {
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* ========== 页面头部 ========== */
.page-header {
  background: linear-gradient(135deg, #00b26a 0%, #00d48a 100%);
  padding: 48rpx 36rpx 56rpx;
}
.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}
.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ========== 表单区域 ========== */
.form-section {
  background: #fff;
  margin: -24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 12rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.form-item {
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}
.label-hint {
  font-size: 22rpx;
  font-weight: normal;
  color: #bbb;
}

/* 输入框 */
.form-input {
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}

/* 文本框 */
.form-textarea {
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  min-height: 200rpx;
  width: 100%;
  box-sizing: border-box;
  line-height: 1.8;
}

.placeholder {
  color: #bbb;
}

/* ========== 图片网格 ========== */
.image-grid {
  display: flex;
  flex-wrap: wrap;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.image-item image {
  width: 100%;
  height: 100%;
}
.image-delete {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.image-delete text {
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}

/* 添加图片按钮 */
.image-add {
  width: 200rpx;
  height: 200rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  border: 2rpx dashed #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}
.add-icon-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.camera-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}
.add-text {
  font-size: 22rpx;
  color: #bbb;
}

/* ========== 日期选择 ========== */
.date-picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}
.date-value {
  font-size: 28rpx;
  color: #333;
}
.date-value.empty {
  color: #bbb;
}
.date-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: bold;
}

/* ========== 标签选择 ========== */
.tag-picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}
.tag-value {
  font-size: 28rpx;
  color: #333;
}
.tag-value.empty {
  color: #bbb;
}
.tag-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}
.tag-option {
  background: #f0f0f0;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
}
.tag-option.active {
  background: rgba(0, 178, 106, 0.1);
  border-color: #00b26a;
}
.tag-option text {
  font-size: 26rpx;
  color: #555;
}
.tag-option.active text {
  color: #00b26a;
  font-weight: bold;
}



/* ========== 发布按钮 ========== */
.publish-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 36rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.publish-btn {
  background: linear-gradient(135deg, #00b26a 0%, #00d48a 100%);
  border-radius: 48rpx;
  padding: 22rpx 0;
  text-align: center;
}
.publish-btn:active {
  opacity: 0.85;
}
.publish-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}
