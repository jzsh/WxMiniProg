<!--pages/mine/mine.wxml-->
<view class="mine-page">

  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-avatar-wrap" bindtap="goToSettings">
      <image class="user-avatar" wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-avatar-placeholder" wx:else>
        <text class="avatar-text">{{displayName[0]}}</text>
      </view>
      <view class="avatar-edit">
        <text>编辑</text>
      </view>
    </view>
    <view class="user-info">
      <text class="user-name">{{displayName}}</text>
      <view class="user-id" bindtap="copyUserId">
        <text class="id-label">ID: {{userId}}</text>
        <text class="id-copy">复制</text>
      </view>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-row">
    <view class="stat-item" bindtap="goToDiary">
      <text class="stat-num">{{diaryCount}}</text>
      <text class="stat-label">日记</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="goToPhoto">
      <text class="stat-num">{{photoCount}}</text>
      <text class="stat-label">照片</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="goToAll">
      <text class="stat-num">{{diaryCount + photoCount}}</text>
      <text class="stat-label">记录</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-section">
    <view class="menu-item" wx:for="{{menuList}}" wx:key="index" bindtap="onMenuTap" data-index="{{index}}">
      <text class="menu-icon">{{item.icon}}</text>
      <view class="menu-content">
        <text class="menu-title">{{item.title}}</text>
        <text class="menu-desc">{{item.desc}}</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 底部版本 -->
  <view class="version-info">
    <text>觅光手记 {{version}}</text>
  </view>

</view>
