/* pages/memo/memo.wxss */
page { background: #f5f5f5; }
.memo-page { padding: 20rpx 24rpx; }
.add-btn { background: #00b26a; color: #fff; text-align: center; padding: 20rpx; border-radius: 12rpx; margin-bottom: 20rpx; font-size: 28rpx; }
.add-btn:active { opacity: 0.8; }
.add-box { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.memo-title-input { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; border-bottom: 1rpx solid #f0f0f0; padding-bottom: 16rpx; }
.memo-content-input { font-size: 28rpx; color: #555; min-height: 120rpx; width: 100%; line-height: 1.6; }
.add-actions { display: flex; gap: 20rpx; justify-content: flex-end; margin-top: 16rpx; }
.btn-cancel text, .btn-confirm text { font-size: 26rpx; padding: 8rpx 28rpx; border-radius: 24rpx; }
.btn-cancel text { color: #999; }
.btn-confirm text { color: #fff; background: #00b26a; }
.memo-list { display: flex; flex-direction: column; gap: 16rpx; }
.memo-card { border-radius: 16rpx; padding: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.memo-title { font-size: 30rpx; font-weight: bold; color: #333; display: block; margin-bottom: 8rpx; }
.memo-content { font-size: 26rpx; color: #666; line-height: 1.6; display: block; margin-bottom: 12rpx; }
.memo-time { font-size: 20rpx; color: #bbb; }
.empty-hint { text-align: center; padding: 120rpx 0; font-size: 28rpx; color: #ccc; }
