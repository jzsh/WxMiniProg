/* pages/period/period.wxss */
page { background: #f5f6fa; }
.period-page { padding: 20rpx 24rpx; padding-bottom: 80rpx; }

/* ===== 日历卡片 ===== */
.calendar-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.cal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0 20rpx;
}
.cal-header text[bindtap] {
  font-size: 44rpx;
  color: #ff6b9d;
  width: 64rpx;
  text-align: center;
  padding: 8rpx 0;
}
.cal-title { font-size: 32rpx; font-weight: bold; color: #333; }

/* 拖动提示 */
.drag-tip {
  text-align: center;
  background: linear-gradient(135deg, #fff5f8, #fef0ff);
  border-radius: 12rpx;
  padding: 14rpx 20rpx;
  margin-bottom: 16rpx;
}
.drag-tip text {
  font-size: 26rpx;
  color: #d63384;
  font-weight: 500;
}

.cal-weekdays {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 12rpx;
  margin-bottom: 8rpx;
}
.weekday {
  width: 14.28%;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

/* ===== 日期格子 ===== */
.cal-days { display: flex; flex-wrap: wrap; touch-action: none; }
.day-cell {
  width: 14.28%;
  height: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  margin: 2rpx 0;
  border-radius: 14rpx;
  transition: background 0.1s;
  touch-action: none;
}
.day-cell.empty { visibility: hidden; }

.day-num {
  font-size: 28rpx;
  color: #333;
  line-height: 1;
}

/* 今天 */
.day-cell.today .day-num {
  background: linear-gradient(135deg, #ff6b9d, #ff8fab);
  color: #fff;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 50%;
  text-align: center;
  font-weight: bold;
  font-size: 26rpx;
}

/* 选中 */
.day-cell.selected { background: rgba(255,107,157,0.2); }
.day-cell.selected .day-num { color: #ff6b9d; font-weight: bold; }

/* 拖动范围 */
.day-cell.in-range {
  background: rgba(255,107,157,0.15);
}

/* 背景色标记 */
.day-cell.has-period { background: rgba(255,158,176,0.28); }
.day-cell.has-period .day-num { color: #c44569; }
.day-cell.has-love { background: rgba(167,139,250,0.28); }
.day-cell.has-love .day-num { color: #7c5cdd; }
.day-cell.has-ovu { background: rgba(74,222,128,0.25); }
.day-cell.has-ovu .day-num { color: #2e9e5a; }

/* 叠加 */
.day-cell.has-period.has-love { background: linear-gradient(135deg, rgba(255,158,176,0.35), rgba(167,139,250,0.25)); }
.day-cell.has-period.has-ovu { background: linear-gradient(135deg, rgba(255,158,176,0.35), rgba(74,222,128,0.2)); }
.day-cell.has-love.has-ovu { background: linear-gradient(135deg, rgba(167,139,250,0.35), rgba(74,222,128,0.2)); }
.day-cell.has-period.has-love.has-ovu { background: linear-gradient(135deg, rgba(255,158,176,0.3), rgba(167,139,250,0.25), rgba(74,222,128,0.2)); }

/* 选中/拖动优先级最高 */
.day-cell.selected.has-period,
.day-cell.selected.has-love,
.day-cell.selected.has-ovu { background: rgba(255,107,157,0.35); }
.day-cell.in-range.has-period { background: linear-gradient(135deg, rgba(255,158,176,0.4), rgba(255,107,157,0.2)); }
.day-cell.in-range.has-love { background: linear-gradient(135deg, rgba(167,139,250,0.4), rgba(255,107,157,0.2)); }
.day-cell.in-range.has-ovu { background: linear-gradient(135deg, rgba(74,222,128,0.35), rgba(255,107,157,0.2)); }

/* 标记图标 */
.day-icons { display: flex; gap: 2rpx; margin-top: 2rpx; }
.mark-icon { font-size: 18rpx; line-height: 1; }

/* ===== 图例 ===== */
.period-legend {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}
.legend-item { display: flex; align-items: center; gap: 8rpx; }
.legend-item text { font-size: 22rpx; color: #888; }
.legend-swatch { width: 26rpx; height: 26rpx; border-radius: 6rpx; }
.legend-swatch.period-bg { background: rgba(255,158,176,0.5); }
.legend-swatch.love-bg { background: rgba(167,139,250,0.5); }
.legend-swatch.ovu-bg { background: rgba(74,222,128,0.45); }
.legend-swatch.today-swatch { background: linear-gradient(135deg, #ff6b9d, #ff8fab); }

.usage-tip { text-align: center; margin-top: 14rpx; }
.usage-tip text { font-size: 22rpx; color: #ccc; }

/* ===== 面板通用 ===== */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 20rpx;
}
.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.panel-date { font-size: 32rpx; font-weight: bold; color: #333; }
.clear-btn {
  font-size: 26rpx; color: #ff6b9d; padding: 8rpx 20rpx;
  background: rgba(255,107,157,0.08); border-radius: 20rpx;
}
.section-label { font-size: 26rpx; color: #666; margin-bottom: 16rpx; font-weight: 500; }

/* ===== 单日详情 ===== */
.records-section { margin-bottom: 28rpx; }
.record-chips { display: flex; flex-wrap: wrap; gap: 16rpx; }
.record-chip {
  display: flex; align-items: center; gap: 12rpx;
  padding: 14rpx 20rpx; border-radius: 12rpx; font-size: 26rpx;
}
.record-chip.period { background: rgba(255,158,176,0.15); color: #c44569; }
.record-chip.love { background: rgba(167,139,250,0.15); color: #7c5cdd; }
.record-chip.ovu { background: rgba(74,222,128,0.15); color: #2e9e5a; }
.chip-del { font-size: 32rpx; color: #ccc; padding: 0 8rpx; }
.chip-del:active { color: #e74c3c; }
.no-record-hint { font-size: 26rpx; color: #ccc; padding: 16rpx 0; }

/* 添加按钮 */
.add-row { display: flex; gap: 16rpx; }
.add-btn {
  flex: 1; display: flex; align-items: center; justify-content: center;
  padding: 24rpx 12rpx; border-radius: 14rpx; font-size: 26rpx; transition: all 0.15s;
}
.add-btn:active { transform: scale(0.96); opacity: 0.85; }
.period-btn { background: rgba(255,158,176,0.15); color: #c44569; }
.love-btn { background: rgba(167,139,250,0.15); color: #7c5cdd; }
.ovu-btn { background: rgba(74,222,128,0.15); color: #2e9e5a; }

/* ===== 范围操作区 ===== */
.range-panel { border-left: 6rpx solid #ff6b9d; }
.range-hint {
  background: #fafafa; border-radius: 12rpx; padding: 24rpx; text-align: center; margin-bottom: 24rpx;
}
.range-hint text { display: block; font-size: 28rpx; color: #666; }
.range-actions { }
.action-label { font-size: 26rpx; color: #666; margin-bottom: 16rpx; font-weight: 500; }
.delete-row { margin-top: 24rpx; padding-top: 24rpx; border-top: 1rpx solid #f0f0f0; }
.btn-delete-range {
  display: flex; align-items: center; justify-content: center;
  padding: 24rpx; background: rgba(231,76,60,0.06); border-radius: 14rpx;
}
.btn-delete-range text { font-size: 26rpx; color: #e74c3c; }
.btn-delete-range:active { background: rgba(231,76,60,0.12); }

/* ===== 提示面板 ===== */
.hint-panel .hint-box { text-align: center; padding: 48rpx 20rpx; }
.hint-main { display: block; font-size: 28rpx; color: #bbb; margin-bottom: 12rpx; }
.hint-sub { display: block; font-size: 24rpx; color: #ddd; }