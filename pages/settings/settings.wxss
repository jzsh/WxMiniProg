.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

/* 头像 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
  background: linear-gradient(135deg, #00b26a, #00d47e);
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.6);
}

.avatar-hint {
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
  margin-top: 16rpx;
}

/* 表单 */
.form-section {
  margin: 30rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 140rpx;
  font-size: 30rpx;
  color: #333;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.form-picker {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  font-size: 28rpx;
  color: #ccc;
  margin-left: 12rpx;
}

/* 保存按钮 */
.btn-save {
  margin: 40rpx 24rpx 0;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #00b26a, #00d47e);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 178, 106, 0.3);
}

/* 数据管理区域 */
.data-section {
  margin: 30rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  padding: 28rpx 30rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.data-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.data-item:last-child {
  border-bottom: none;
}

.data-item.danger {
  border-left: 4rpx solid #e74c3c;
}

.data-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.data-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.data-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.data-desc {
  font-size: 25rpx;
  color: #999;
}

.warning-text {
  color: #e74c3c;
  font-weight: 500;
}
