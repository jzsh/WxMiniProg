/* pages/favorites/favorites.wxss */
page { background: #f5f5f5; }
.container { padding: 20rpx 24rpx; }
.empty { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.empty-icon { width: 160rpx; height: 160rpx; border-radius: 50%; margin-bottom: 24rpx; opacity: 0.5; }
.empty-text { font-size: 32rpx; color: #999; margin-bottom: 12rpx; }
.empty-hint { font-size: 24rpx; color: #ccc; }
.list { display: flex; flex-direction: column; gap: 16rpx; }
.fav-item { display: flex; align-items: center; background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.fav-cover { width: 160rpx; height: 160rpx; flex-shrink: 0; }
.fav-cover image { width: 100%; height: 100%; }
.fav-cover-default { display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #667eea, #764ba2); }
.cover-placeholder { font-size: 60rpx; }
.fav-info { flex: 1; padding: 20rpx 24rpx; }
.fav-title { font-size: 30rpx; font-weight: bold; color: #333; display: block; margin-bottom: 8rpx; }
.fav-meta { display: flex; align-items: center; gap: 12rpx; }
.fav-date { font-size: 22rpx; color: #bbb; }
.fav-divider { font-size: 22rpx; color: #ddd; }
.fav-tag { font-size: 22rpx; color: #00b26a; background: rgba(0,178,106,0.1); padding: 2rpx 12rpx; border-radius: 12rpx; }
.fav-mood { font-size: 22rpx; color: #888; }
.fav-remove { padding: 20rpx 24rpx; }
.remove-icon { font-size: 28rpx; color: #ccc; }
