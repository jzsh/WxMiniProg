/* pages/recycle_bin/recycle_bin.wxss */
page { background-color: #f5f5f5; }
.bin-page { padding: 20rpx 24rpx; padding-bottom: 120rpx; }
.section { margin-bottom: 24rpx; }
.section-header { margin-bottom: 16rpx; padding: 0 8rpx; }
.section-title { font-size: 30rpx; font-weight: bold; color: #333; }

.recycle-list { background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.recycle-item { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 28rpx; border-bottom: 1rpx solid #f5f5f5; }
.recycle-item:last-child { border-bottom: none; }
.recycle-info { flex: 1; }
.recycle-title { font-size: 28rpx; color: #333; font-weight: bold; display: block; margin-bottom: 4rpx; }
.recycle-date { font-size: 22rpx; color: #bbb; }
.recycle-actions { display: flex; gap: 20rpx; flex-shrink: 0; }
.action-restore { font-size: 24rpx; color: #00b26a; padding: 8rpx 20rpx; background: rgba(0,178,106,0.1); border-radius: 20rpx; }
.action-delete { font-size: 24rpx; color: #ff4757; padding: 8rpx 20rpx; background: rgba(255,71,87,0.1); border-radius: 20rpx; }

.photo-grid { display: flex; flex-wrap: wrap; gap: 12rpx; background: #fff; border-radius: 16rpx; padding: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.photo-item { width: calc(25% - 9rpx); position: relative; }
.photo-item image { width: 100%; height: 180rpx; border-radius: 8rpx; }
.photo-actions { display: flex; gap: 8rpx; margin-top: 8rpx; justify-content: center; }
.photo-actions .action-restore { font-size: 20rpx; padding: 4rpx 12rpx; }
.photo-actions .action-delete { font-size: 20rpx; padding: 4rpx 12rpx; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: #999; margin-bottom: 12rpx; }
.empty-hint { font-size: 24rpx; color: #ccc; }

.clear-btn { position: fixed; bottom: 0; left: 0; right: 0; text-align: center; padding: 24rpx; background: #fff; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06); padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); }
.clear-btn text { font-size: 28rpx; color: #ff4757; }
